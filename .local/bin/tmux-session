#!/bin/bash

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tmux"
CONFIG_TEMPLATES_DIR="$CONFIG_DIR/templates"
CONFIG_TEMPLATES_DEFAULT_FILE="$CONFIG_TEMPLATES_DIR/default.sh"

mkdir -p "$CONFIG_DIR"
mkdir -p "$CONFIG_TEMPLATES_DIR"

if [[ ! -f "$CONFIG_TEMPLATES_DEFAULT_FILE" ]]; then
  cat >"$CONFIG_TEMPLATES_DEFAULT_FILE" <<'EOF'
#!/bin/bash

name="$1"
path="$2"

tmux new-session -d -s "$name" -c "$path" -n 'main'
tmux select-window -t "$name:main"
EOF
  chmod +x "$CONFIG_TEMPLATES_DEFAULT_FILE"
fi

DEFAULT_TMUX_SESSION_PATHS=(
  "$HOME"
  "$HOME/projects/"*
  "$HOME/.dotfiles"
  "$HOME/.dotfiles/.config/nvim"
  "$HOME/.dotfiles/.config/tmux"
  "$WIN_HOME"
)

if [[ -n "$TMUX_SESSION_PATHS" ]]; then
  IFS=: read -ra PATHS <<<"$TMUX_SESSION_PATHS"
else
  PATHS=("${DEFAULT_TMUX_SESSION_PATHS[@]}")
fi

get_paths() {
  for p in "${PATHS[@]}"; do
    [[ -d "$p" ]] && echo "$p"
  done
}

print_usage() {
  echo "Usage: tmux-sessions [OPTIONS] [dir]

Attach to a tmux session for a directory.

Options:
  -h, --help                  Show this help message and exit.
  -a, --active-dirs           Pick from active tmux session paths via fzf.
  -d, --dirs [dir...]         List known directories. If paths are given, override the list.
  -D, --append-dirs [dir...]  Append directories to the list for this invocation."
}

resolve_path() {
  local p="${1/#\~/$HOME}"
  [[ "$p" != /* ]] && p="$(realpath -m "$p")"
  echo "$p"
}

has_session() {
  tmux list-sessions -F "#{session_name}" 2>/dev/null | grep -Fxq "$1"
}

session_name_from_path() {
  echo "$1" |
    sed "s|^$HOME|~|" |
    sed 's/\./_/g'
}

template_path_from_path() {
  echo "${1/#$HOME/}" | sed 's|^/||'
}

new_session() {
  local name="$1"
  local path="$2"

  local template_rel
  template_rel=$(template_path_from_path "$path")
  local template_file="$CONFIG_TEMPLATES_DIR/$template_rel.sh"
  local local_template="$path/.tmux-session"

  if [[ -f "$local_template" ]]; then
    "$local_template" "$name" "$path"
  elif [[ -f "$template_file" ]]; then
    "$template_file" "$name" "$path"
  else
    mkdir -p "$(dirname "$template_file")"
    cp "$CONFIG_TEMPLATES_DEFAULT_FILE" "$template_file"
    chmod +x "$template_file"
    "$template_file" "$name" "$path"
  fi
}

attach_or_switch() {
  local name="$1"
  if [[ -n "$TMUX" ]]; then
    tmux switch-client -t "$name"
  else
    tmux attach-session -t "$name"
  fi
}

list_dirs() {
  get_paths | sed "s|^$HOME|~|"
}

main() {
  local active_dirs=false
  local explicit_dir=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      print_usage
      exit 0
      ;;
    -a | --active-dirs)
      active_dirs=true
      shift
      ;;
    -d | --dirs)
      shift
      if [[ $# -gt 0 ]]; then
        PATHS=()
        while [[ $# -gt 0 && "$1" != -* ]]; do
          PATHS+=("$(resolve_path "$1")")
          shift
        done
      fi
      list_dirs
      exit 0
      ;;
    -D | --append-dirs)
      shift
      while [[ $# -gt 0 && "$1" != -* ]]; do
        PATHS+=("$(resolve_path "$1")")
        shift
      done
      ;;
    --)
      shift
      explicit_dir="${1:-}"
      break
      ;;
    -*)
      echo "Unknown option: $1"
      print_usage
      exit 1
      ;;
    *)
      explicit_dir="$1"
      shift
      ;;
    esac
  done

  local target_path=""

  if [[ -n "$explicit_dir" ]]; then
    target_path="$(resolve_path "$explicit_dir")"
    if [[ ! -d "$target_path" ]]; then
      echo "Error: not a directory: $target_path"
      exit 1
    fi

  elif $active_dirs; then
    local selected
    selected=$(tmux list-sessions -F "#{session_path}" 2>/dev/null |
      sed "s|^$HOME|~|" |
      fzf --prompt="active session> ")
    [[ -z "$selected" ]] && exit 1
    target_path="${selected/#\~/$HOME}"

  else
    mapfile -t pool < <(get_paths)

    if [[ ${#pool[@]} -eq 0 ]]; then
      echo "No directories found. Pass a path directly or set TMUX_SESSION_PATHS."
      exit 1
    fi

    local selected
    selected=$(printf "%s\n" "${pool[@]}" | sed "s|^$HOME|~|" | fzf --prompt="session> ")
    [[ -z "$selected" ]] && exit 1
    target_path="${selected/#\~/$HOME}"
  fi

  local session_name
  session_name=$(session_name_from_path "$target_path")

  if ! has_session "$session_name"; then
    new_session "$session_name" "$target_path"
  fi

  attach_or_switch "$session_name"
}

main "$@"
