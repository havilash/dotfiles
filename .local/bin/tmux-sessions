#!/bin/bash

PATHS=(
  "$HOME"
  "$HOME/projects/"*
  "$HOME/projects/infravista/"*
  "$HOME/.dotfiles"
  "$HOME/.dotfiles/.config/nvim"
  "$HOME/.dotfiles/.tmux/templates"
  "$WIN_HOME"
)

EXISTING_PATHS=()
for p in "${PATHS[@]}"; do
  [[ -d "$p" ]] && EXISTING_PATHS+=("$p")
done

TMUX_TEMPLATES_PATH="$HOME/.tmux/templates"

print_usage() {
  echo "Usage: tmux-sessions [OPTIONS] <dir1> [dir2 ...]

Tmux sessions

Options:
  -h, --help                Show this help message and exit.
  -a, --active              List all active tmux sessions."
}

has_session() {
  local name="$1"
  tmux list-sessions -F "#{session_name}" 2>/dev/null | grep -Fxq "$name"
}

new_session() {
  local name="$1"
  local path="$2"

  local template_name
  template_name=$(echo "$path" | sed "s|^$HOME|~|" | sed -E 's/^(~\/|\/)|\.//g' | sed 's/\//__/g')

  local template_file
  template_file="$TMUX_TEMPLATES_PATH/$template_name"

  if [[ -f "$template_file" ]]; then
    "$template_file" "$name" "$path"
  else
    mkdir -p "$(dirname "$template_file")"
    cp "$TMUX_TEMPLATES_PATH/default" "$template_file"
    "$template_file" "$name" "$path"
  fi
}

main() {
  local -a dirs=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      print_usage
      exit 0
      ;;
    -a | --active)
      mapfile -t dirs < <(tmux list-sessions -F "#{session_path}")
      shift
      ;;
    *)
      dirs+=("$1")
      shift
      ;;
    esac
  done

  if [[ ${#dirs[@]} -eq 0 ]]; then
    dirs=("${EXISTING_PATHS[@]}")
  fi

  local selected
  selected=$(printf "%s\n" "${dirs[@]}" | sed "s|^$HOME|~|" | fzf)
  [[ ! $selected ]] && exit 1

  local selected_name
  selected_name="${selected//[\.]/_}"

  if ! has_session "$selected_name"; then
    new_session "$selected_name" "${selected//\~/$HOME}"
  fi

  if [[ -n $TMUX ]]; then
    tmux switch-client -t "$selected_name"
  else
    tmux attach-session -t "$selected_name"
  fi
}

main "$@"
