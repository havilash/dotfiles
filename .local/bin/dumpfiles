#!/bin/bash

print_usage() {
  echo "Usage: dumpfiles [OPTIONS]

Reads a list of files from stdin and displays paths with contents.

Options:
  -h, --help       Show help message
"
}

main() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      print_usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      print_usage
      exit 1
      ;;
    esac
  done

  while IFS= read -r file; do
    [[ -f "$file" ]] || continue

    echo "===== $file ====="
    cat "$file"
    echo
  done
}

main "$@"
